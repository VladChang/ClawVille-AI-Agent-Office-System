# Docker compose defaults
CORS_ORIGIN=http://localhost:3000
RUNTIME_SOURCE=mock
ALLOW_RUNTIME_FALLBACK=false
OPENCLAW_RUNTIME_ENDPOINT=
OPENCLAW_RUNTIME_API_KEY=
OPENCLAW_RUNTIME_POLL_MS=5000
OPENCLAW_RUNTIME_AUTH_HEADER=authorization
OPENCLAW_RUNTIME_AUTH_SCHEME=Bearer
OPENCLAW_RUNTIME_SNAPSHOT_PATH=/snapshot
OPENCLAW_RUNTIME_AGENTS_PATH=/agents
OPENCLAW_RUNTIME_TASKS_PATH=/tasks
OPENCLAW_RUNTIME_EVENTS_PATH=/events
RUNTIME_PERSISTENCE_ENABLED=true
RUNTIME_PERSISTENCE_FILE=/app/.data/runtime-state.json
AUTH_MODE=off
AUDIT_LOG_ENABLED=true
AUDIT_LOG_FILE=/app/.data/audit-log.jsonl
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api
NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws
NEXT_PUBLIC_RUNTIME_MODE=local
NEXT_PUBLIC_OPERATOR_ID=demo-operator
NEXT_PUBLIC_OPERATOR_ROLE=operator
