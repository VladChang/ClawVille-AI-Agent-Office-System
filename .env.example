# Docker compose defaults
CORS_ORIGIN=http://localhost:3000
RUNTIME_SOURCE=mock
ALLOW_RUNTIME_FALLBACK=false
OPENCLAW_ADAPTER_ENDPOINT=http://adapter:3010
OPENCLAW_ADAPTER_API_KEY=
OPENCLAW_ADAPTER_AUTH_HEADER=authorization
OPENCLAW_ADAPTER_AUTH_SCHEME=Bearer
OPENCLAW_ADAPTER_SNAPSHOT_PATH=/snapshot
OPENCLAW_ADAPTER_AGENTS_PATH=/agents
OPENCLAW_ADAPTER_TASKS_PATH=/tasks
OPENCLAW_ADAPTER_EVENTS_PATH=/events
OPENCLAW_RUNTIME_POLL_MS=5000
OPENCLAW_RUNTIME_POLL_MAX_BACKOFF_MS=30000
OPENCLAW_RUNTIME_REQUEST_TIMEOUT_MS=5000
OPENCLAW_INTERNAL_BASE_URL=
OPENCLAW_INTERNAL_API_KEY=
OPENCLAW_INTERNAL_AUTH_HEADER=authorization
OPENCLAW_INTERNAL_AUTH_SCHEME=Bearer
OPENCLAW_INTERNAL_REQUEST_TIMEOUT_MS=5000
OPENCLAW_INTERNAL_HEALTH_PATH=/health
OPENCLAW_INTERNAL_SNAPSHOT_PATH=/snapshot
OPENCLAW_INTERNAL_AGENTS_PATH=/agents
OPENCLAW_INTERNAL_TASKS_PATH=/tasks
OPENCLAW_INTERNAL_EVENTS_PATH=/events
OPENCLAW_INTERNAL_AGENT_PAUSE_PATH_TEMPLATE=/agents/:id/pause
OPENCLAW_INTERNAL_AGENT_RESUME_PATH_TEMPLATE=/agents/:id/resume
OPENCLAW_INTERNAL_TASK_RETRY_PATH_TEMPLATE=/tasks/:id/retry
OPENCLAW_ADAPTER_ALIAS_FILE=/app/backend/.data/openclaw-agent-aliases.json
RUNTIME_PERSISTENCE_ENABLED=true
RUNTIME_PERSISTENCE_FILE=/app/.data/runtime-state.json
AUTH_MODE=off
AUDIT_LOG_ENABLED=true
AUDIT_LOG_FILE=/app/.data/audit-log.jsonl
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api
NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws
NEXT_PUBLIC_RUNTIME_MODE=local
NEXT_PUBLIC_OPERATOR_ID=demo-operator
NEXT_PUBLIC_OPERATOR_ROLE=operator
