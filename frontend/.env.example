# Frontend runtime config
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api
NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws

# Runtime mode: mock | local | real
# - mock: always use local frontend mock data
# - local: try backend API, fallback to mock data when unavailable (default in dev)
# - real: strict backend API only (default in prod); runtime failures are shown as strict-mode errors
NEXT_PUBLIC_RUNTIME_MODE=local

# Backward-compatible legacy flag (still honored)
NEXT_PUBLIC_USE_MOCK_API=false
