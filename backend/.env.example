PORT=3001
HOST=127.0.0.1
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000

RUNTIME_SOURCE=mock
ALLOW_RUNTIME_FALLBACK=false
OPENCLAW_RUNTIME_ENDPOINT=
OPENCLAW_RUNTIME_API_KEY=

RUNTIME_PERSISTENCE_ENABLED=true
RUNTIME_PERSISTENCE_FILE=.data/runtime-state.json
RUNTIME_MAX_EVENTS=500
RUNTIME_MAX_TASK_TRANSITIONS=1000
RUNTIME_MAX_AGENT_STATUS_CHANGES=1000
RUNTIME_PERSISTENCE_FLUSH_MS=200

AUTH_MODE=off

AUDIT_LOG_ENABLED=true
AUDIT_LOG_FILE=.data/audit-log.jsonl
AUDIT_MAX_IN_MEMORY_RECORDS=1000
AUDIT_LOG_FLUSH_MS=200
