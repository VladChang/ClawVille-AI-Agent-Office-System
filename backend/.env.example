# Backend server config
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# CORS. Set to frontend origin for stricter local dev
# Example: http://localhost:3000
CORS_ORIGIN=

# Backend runtime source: mock | openclaw
# - mock: current in-memory runtime source
# - openclaw: runtime transport path (strict degraded mode when no runtime input is configured)
RUNTIME_SOURCE=mock

# OpenClaw adapter settings (for real integration in openclaw mode)
OPENCLAW_RUNTIME_ENDPOINT=
OPENCLAW_RUNTIME_API_KEY=

# Optional integration fixture transport (useful for local/integration tests)
OPENCLAW_RUNTIME_FIXTURE_PATH=
OPENCLAW_RUNTIME_FIXTURE_JSON=

# Safety switch: openclaw mode will NOT silently fall back to mock unless this is true
ALLOW_RUNTIME_FALLBACK=false

# Optional durable local persistence for mock/runtime state history
RUNTIME_PERSISTENCE_ENABLED=false
RUNTIME_PERSISTENCE_FILE=.data/runtime-state.json
