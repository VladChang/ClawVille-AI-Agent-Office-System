# Backend server config
PORT=3001
HOST=0.0.0.0

# CORS. Set to frontend origin for stricter local dev
# Example: http://localhost:3000
CORS_ORIGIN=

# Backend runtime source: mock | openclaw
# - mock: current in-memory runtime source
# - openclaw: Round 1 placeholder adapter (currently proxied to mock fallback)
RUNTIME_SOURCE=mock
