# Backend server config
PORT=3001
HOST=0.0.0.0

# CORS. Set to frontend origin for stricter local dev
# Example: http://localhost:3000
CORS_ORIGIN=

# Backend runtime source: mock | openclaw
# - mock: current in-memory runtime source
# - openclaw: Round 2 adapter skeleton (strict degraded mode by default)
RUNTIME_SOURCE=mock

# OpenClaw adapter settings (required for real integration in openclaw mode)
OPENCLAW_RUNTIME_ENDPOINT=
OPENCLAW_RUNTIME_API_KEY=

# Safety switch: openclaw mode will NOT silently fall back to mock unless this is true
ALLOW_RUNTIME_FALLBACK=false
