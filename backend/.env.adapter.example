PORT=3010
HOST=127.0.0.1
LOG_LEVEL=info

OPENCLAW_INTERNAL_BASE_URL=
OPENCLAW_INTERNAL_API_KEY=
OPENCLAW_INTERNAL_AUTH_HEADER=authorization
OPENCLAW_INTERNAL_AUTH_SCHEME=Bearer
OPENCLAW_INTERNAL_REQUEST_TIMEOUT_MS=5000

OPENCLAW_INTERNAL_HEALTH_PATH=/health
OPENCLAW_INTERNAL_SNAPSHOT_PATH=/snapshot
OPENCLAW_INTERNAL_AGENTS_PATH=/agents
OPENCLAW_INTERNAL_TASKS_PATH=/tasks
OPENCLAW_INTERNAL_EVENTS_PATH=/events
OPENCLAW_INTERNAL_AGENT_PAUSE_PATH_TEMPLATE=/agents/:id/pause
OPENCLAW_INTERNAL_AGENT_RESUME_PATH_TEMPLATE=/agents/:id/resume
OPENCLAW_INTERNAL_TASK_RETRY_PATH_TEMPLATE=/tasks/:id/retry

OPENCLAW_ADAPTER_ALIAS_FILE=.data/openclaw-agent-aliases.json
